---
import { execSync } from 'child_process';

const { entry } = Astro.locals.starlightRoute;

// Try frontmatter overrides first, then fall back to git history
let published: string = (entry.data as any).published ?? '';
let lastEdited: string = (entry.data as any).lastEdited ?? '';

if (!published || !lastEdited) {
  // Find the actual file — could be .md or .mdx
  const bases = [
    `src/content/docs/${entry.id}.md`,
    `src/content/docs/${entry.id}.mdx`,
  ];
  const filePath = bases.find(p => {
    try { execSync(`test -f "${p}"`); return true; } catch { return false; }
  }) ?? bases[0];

  try {
    if (!lastEdited) {
      lastEdited = execSync(
        `git log -1 --format="%ad" --date=short -- "${filePath}"`,
        { encoding: 'utf-8', stdio: ['pipe', 'pipe', 'ignore'] }
      ).trim();
    }
    if (!published) {
      published = execSync(
        `git log --follow --diff-filter=A --format="%ad" --date=short -- "${filePath}"`,
        { encoding: 'utf-8', stdio: ['pipe', 'pipe', 'ignore'] }
      ).trim();
    }
  } catch {
    // git unavailable or file not committed yet
  }
}

const fmt = (d: string) => {
  if (/^\d{4}$/.test(d)) return d;
  const [year, month, day] = d.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const showLastEdited = lastEdited && lastEdited !== published;
---

<h1 id="_top">{entry.data.title}</h1>

{(published || showLastEdited) && (
  <div class="page-dates">
    {published && <span>Published: {fmt(published)}</span>}
    {published && showLastEdited && <span class="separator">·</span>}
    {showLastEdited && <span>Last edited: {fmt(lastEdited)}</span>}
  </div>
)}

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }

  .page-dates {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
    margin-top: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .separator {
    color: var(--sl-color-gray-5);
  }
</style>
