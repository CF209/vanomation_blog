---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import config from 'virtual:starlight/user-config';
import type { ImageMetadata } from 'astro';

// Auto-discovers thumbnails from src/assets/img/thumbnails/{slug}.{ext}
// To add a thumbnail for a new tutorial, just drop a file there named after its slug.
const thumbnailGlob = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/img/thumbnails/*',
  { eager: true }
);
const thumbnails: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(thumbnailGlob)) {
  const slug = path.split('/').pop()!.replace(/\.[^.]+$/, '');
  thumbnails[slug] = mod.default;
}

const allDocs = await getCollection('docs');
const docsBySlug = Object.fromEntries(allDocs.map(e => [e.id, e]));

const groups = (config.sidebar as any[]).filter(group => Array.isArray(group.items)).map(group => ({
  label: group.label as string,
  items: ((group.items ?? []) as any[]).map((item: any) => {
    const slug = item.id ?? item.slug;
    const entry = docsBySlug[slug];
    return {
      slug,
      title: item.label as string,
      href: `/${slug}/`,
      description: (entry?.data.description ?? '') as string,
      thumbnail: thumbnails[slug] ?? null,
    };
  }),
}));
---

{groups.map(group => (
  <div class="overview-group">
    {groups.length > 1 && <h2>{group.label}</h2>}
    <div class="overview-grid">
      {group.items.map(item => (
        <a href={item.href} class="overview-card">
          {item.thumbnail && (
            <div class="overview-card-img">
              <Image src={item.thumbnail} alt={item.title} width={400} />
            </div>
          )}
          <div class="overview-card-body">
            <h3>{item.title}</h3>
            {item.description && <p>{item.description}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>
))}

<style>
  .overview-group {
    margin-bottom: 2.5rem;
  }
  .overview-group:last-child {
    margin-bottom: 0;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .overview-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: var(--sl-color-bg-nav);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .overview-card:hover {
    border-color: var(--sl-color-accent);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
    text-decoration: none;
    color: inherit;
  }

  .overview-card-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--sl-color-bg);
    flex-shrink: 0;
  }

  .overview-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .overview-card-body {
    padding: 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .overview-card-body h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
    color: var(--sl-color-text-accent);
    line-height: 1.3;
  }

  .overview-card:hover .overview-card-body h3 {
    color: var(--sl-color-accent);
  }

  .overview-card-body p {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    margin: 0;
    line-height: 1.5;
  }
</style>
